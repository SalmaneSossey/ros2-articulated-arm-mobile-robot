<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <material name="silver">
    <color rgba="0.80 0.80 0.82 1.0"/>
  </material>
  <material name="black">
    <color rgba="0.08 0.08 0.08 1.0"/>
  </material>

  <xacro:macro name="chassis_link" params="name length width height material:=silver">
    <link name="${name}">
      <visual>
        <geometry>
          <box size="${length} ${width} ${height}"/>
        </geometry>
        <material name="${material}"/>
      </visual>
      <collision>
        <geometry>
          <box size="${length} ${width} ${height}"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <xacro:macro name="wheel_link" params="name radius length material:=black">
    <link name="${name}">
      <visual>
        <!-- URDF cylinders are aligned with the local z-axis by default.
             A wheel's axle should point laterally, so the cylinder is rotated
             around x by 90 degrees to align its long axis with y. -->
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
        <material name="${material}"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="1.57079632679 0 0"/>
        <geometry>
          <cylinder radius="${radius}" length="${length}"/>
        </geometry>
      </collision>
    </link>
  </xacro:macro>

  <xacro:macro name="wheel_joint" params="name parent child xyz">
    <joint name="${name}" type="continuous">
      <parent link="${parent}"/>
      <child link="${child}"/>
      <origin xyz="${xyz}" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
    </joint>
  </xacro:macro>

  <xacro:macro
    name="four_wheel_base"
    params="prefix parent base_xyz base_length base_width base_height wheel_radius wheel_length">
    <xacro:chassis_link
      name="${prefix}base_link"
      length="${base_length}"
      width="${base_width}"
      height="${base_height}"/>

    <joint name="${prefix}world_to_base" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}base_link"/>
      <origin xyz="${base_xyz}" rpy="0 0 0"/>
    </joint>

    <xacro:property name="wheel_x" value="${base_length / 2.0 - wheel_radius}"/>
    <xacro:property name="wheel_y" value="${base_width / 2.0 + wheel_length / 2.0}"/>
    <xacro:property name="wheel_z" value="${-(base_height / 2.0 + wheel_radius)}"/>

    <xacro:wheel_link name="${prefix}front_left_wheel" radius="${wheel_radius}" length="${wheel_length}"/>
    <xacro:wheel_link name="${prefix}front_right_wheel" radius="${wheel_radius}" length="${wheel_length}"/>
    <xacro:wheel_link name="${prefix}rear_left_wheel" radius="${wheel_radius}" length="${wheel_length}"/>
    <xacro:wheel_link name="${prefix}rear_right_wheel" radius="${wheel_radius}" length="${wheel_length}"/>

    <xacro:wheel_joint
      name="${prefix}front_left_wheel_joint"
      parent="${prefix}base_link"
      child="${prefix}front_left_wheel"
      xyz="${wheel_x} ${wheel_y} ${wheel_z}"/>
    <xacro:wheel_joint
      name="${prefix}front_right_wheel_joint"
      parent="${prefix}base_link"
      child="${prefix}front_right_wheel"
      xyz="${wheel_x} ${-wheel_y} ${wheel_z}"/>
    <xacro:wheel_joint
      name="${prefix}rear_left_wheel_joint"
      parent="${prefix}base_link"
      child="${prefix}rear_left_wheel"
      xyz="${-wheel_x} ${wheel_y} ${wheel_z}"/>
    <xacro:wheel_joint
      name="${prefix}rear_right_wheel_joint"
      parent="${prefix}base_link"
      child="${prefix}rear_right_wheel"
      xyz="${-wheel_x} ${-wheel_y} ${wheel_z}"/>
  </xacro:macro>
</robot>

