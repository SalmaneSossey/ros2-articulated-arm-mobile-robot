<?xml version="1.0"?>
<robot name="basic_cylinder_robot">
  <material name="teal">
    <color rgba="0.10 0.55 0.60 1.0"/>
  </material>

  <link name="world"/>

  <link name="base_link">
    <visual>
      <geometry>
        <cylinder radius="0.10" length="0.20"/>
      </geometry>
      <material name="teal"/>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.10" length="0.20"/>
      </geometry>
    </collision>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
  </joint>
</robot>
